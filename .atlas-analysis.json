{
  "projectType": "cli-tool",
  "projectName": "Mailman",
  "projectDescription": "A CLI alternative to Postman for managing and executing HTTP requests from the terminal",
  "theme": "aspen",
  "primaryColor": "#2563eb",
  "lightColor": "#3b82f6",
  "darkColor": "#1e40af",
  "navigation": {
    "groups": [
      {
